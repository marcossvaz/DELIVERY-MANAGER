// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id      String @id @default(uuid())
  name    String
  contact String
  rg      String @unique

  orders Order[]
}

model Order {
  id         String   @id @default(uuid())
  created_at DateTime @default(now())

  client_id String
  client    Client @relation(fields: [client_id], references: [id])

  order_items   Order_Items[]

  delivery_id String
  deliverys   Delivery @relation(fields: [delivery_id], references: [id])

  payment_it String
  payments   Payment @relation(fields: [payment_it], references: [id])
}

model Order_Items {
  id         String @id @default(uuid())
  quantity   Float
  unit_price Float

  item_id String
  items   Item    @relation(fields: [item_id], references: [id])
  orders  Order[]
}

model Item {
  id         String @id @default(uuid())
  sku        String?
  item_name  String
  item_size  Float
  item_price Float

  orders_items Order_Items[]
}

model Delivery {
  id       String @id @default(uuid())
  modality String
  status   Status?

  orders  Order[]
  adrress Adrress[]
}

model Adrress {
  id     String @id @default(uuid())
  city   String
  street String
  evenue String
  cep    String
  uf     String
  is_primary Boolean @default(true)

  delivery_id String
  deliverys   Delivery @relation(fields: [delivery_id], references: [id])
}

enum Status {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
  FAILED
}

model Payment {
  id   String @id @default(uuid())
  type String // EX: cartão de cédito, dinheiro

  total  Float
  orders Order[]
}
